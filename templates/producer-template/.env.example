# Template connector configuration (JSONPlaceholder).
#
# JSONPlaceholder is a free public REST API that does NOT require auth.
# We still thread an API token through the Config so you can see exactly
# where credentials plug in when you rename the template for a real API.

TEMPLATE_API_BASE_URL=https://jsonplaceholder.typicode.com
TEMPLATE_API_TOKEN=anonymous
# TEMPLATE_WEBHOOK_SECRET= # only needed when verifying inbound webhooks
TEMPLATE_WEBHOOK_PORT=8080
