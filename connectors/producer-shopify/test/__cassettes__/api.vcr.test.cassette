      "entries": {
        "{\"body\":\"{\\\"query\\\":\\\"#graphql\\\\nquery AirfoilProducts($first: Int!, $after: String) {\\\\n  products(first: $first, after: $after, sortKey: UPDATED_AT, reverse: true) {\\\\n    nodes {\\\\n      id\\\\n      legacyResourceId\\\\n      title\\\\n      handle\\\\n      descriptionHtml\\\\n      productType\\\\n      vendor\\\\n      status\\\\n      tags\\\\n      createdAt\\\\n      updatedAt\\\\n      publishedAt\\\\n      templateSuffix\\\\n      featuredMedia {\\\\n        ... on MediaImage {\\\\n          image {\\\\n            url\\\\n            altText\\\\n          }\\\\n        }\\\\n      }\\\\n      options(first: 100) {\\\\n        id\\\\n        name\\\\n        position\\\\n        values\\\\n      }\\\\n      variants(first: 25) {\\\\n        nodes {\\\\n          id\\\\n          legacyResourceId\\\\n          title\\\\n          sku\\\\n          barcode\\\\n          price\\\\n          compareAtPrice\\\\n          inventoryPolicy\\\\n          taxable\\\\n          createdAt\\\\n          updatedAt\\\\n        }\\\\n        pageInfo {\\\\n          hasNextPage\\\\n          endCursor\\\\n        }\\\\n      }\\\\n    }\\\\n    pageInfo {\\\\n      hasNextPage\\\\n      endCursor\\\\n    }\\\\n  }\\\\n}\\\\n\\\",\\\"variables\\\":{\\\"after\\\":null,\\\"first\\\":50}}\",\"headers\":{\"accept\":\"application/json\",\"content-length\":\"1105\",\"content-type\":\"application/json\"},\"method\":\"POST\",\"url\":\"https://nothing-really-opjwlcs9.myshopify.com/admin/api/2026-04/graphql.json\"}": {
          "request": {
            "method": "POST",
            "url": "https://nothing-really-opjwlcs9.myshopify.com/admin/api/2026-04/graphql.json",
            "headers": {
              "content-type": "application/json",
              "content-length": "1105",
              "accept": "application/json"
            },
            "body": "{\"query\":\"#graphql\\nquery AirfoilProducts($first: Int!, $after: String) {\\n  products(first: $first, after: $after, sortKey: UPDATED_AT, reverse: true) {\\n    nodes {\\n      id\\n      legacyResourceId\\n      title\\n      handle\\n      descriptionHtml\\n      productType\\n      vendor\\n      status\\n      tags\\n      createdAt\\n      updatedAt\\n      publishedAt\\n      templateSuffix\\n      featuredMedia {\\n        ... on MediaImage {\\n          image {\\n            url\\n            altText\\n          }\\n        }\\n      }\\n      options(first: 100) {\\n        id\\n        name\\n        position\\n        values\\n      }\\n      variants(first: 25) {\\n        nodes {\\n          id\\n          legacyResourceId\\n          title\\n          sku\\n          barcode\\n          price\\n          compareAtPrice\\n          inventoryPolicy\\n          taxable\\n          createdAt\\n          updatedAt\\n        }\\n        pageInfo {\\n          hasNextPage\\n          endCursor\\n        }\\n      }\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n    }\\n  }\\n}\\n\",\"variables\":{\"after\":null,\"first\":50}}"
          },
          "response": {
