    "format": "biome format --write ."
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.25",
    "@effect/vitest": "4.0.0-beta.25",
    "@types/node": "^24.2.0",
    "@useairfoil/effect-http-client": "workspace:*",
    "tsdown": "^0.15.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.25",
    "@useairfoil/connector-kit": "workspace:*",
    "effect": "4.0.0-beta.25"
  }
}
