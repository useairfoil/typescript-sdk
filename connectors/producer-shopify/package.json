{
  "name": "@useairfoil/producer-shopify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "sandbox": "bun --env-file=.env src/sandbox.ts",
