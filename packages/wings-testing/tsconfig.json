{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["node"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": ["node_modules", "dist", "./src/proto/**"]
}
